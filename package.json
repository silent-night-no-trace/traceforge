{
  "name": "traceforge",
  "private": true,
  "version": "0.0.0",
  "description": "Open-source replay and regression testing for AI agents.",
  "license": "MIT",
  "author": "Traceforge contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/silent-night-no-trace/traceforge.git"
  },
  "homepage": "https://github.com/silent-night-no-trace/traceforge#readme",
  "bugs": {
    "url": "https://github.com/silent-night-no-trace/traceforge/issues"
  },
  "keywords": [
    "agents",
    "ai",
    "testing",
    "regression",
    "replay",
    "mcp",
    "playwright",
    "typescript"
  ],
  "packageManager": "pnpm@10.6.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "clean": "rimraf \"apps/*/dist\" \"packages/*/dist\" coverage",
    "dev:cli": "pnpm --filter @traceforge/cli dev",
    "dev:viewer": "pnpm --filter @traceforge/viewer dev",
    "test": "vitest --config vitest.config.ts run",
    "test:coverage": "vitest --config vitest.config.ts run --coverage",
    "test:generated": "vitest --config vitest.generated.config.ts run",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "pnpm -r --if-present typecheck",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.14.0",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^29.0.1",
    "playwright": "^1.51.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.1.0",
    "zod": "^3.24.2"
  }
}
