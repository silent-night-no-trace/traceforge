{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@traceforge/schema": ["packages/schema/src/index.ts"],
      "@traceforge/core": ["packages/core/src/index.ts"],
      "@traceforge/adapter-terminal": ["packages/adapter-terminal/src/index.ts"],
      "@traceforge/adapter-mcp": ["packages/adapter-mcp/src/index.ts"],
      "@traceforge/fixtures": ["packages/fixtures/src/index.ts"],
      "@traceforge/adapter-browser": ["packages/adapter-browser/src/index.ts"]
    },
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "useDefineForClassFields": true,
    "types": ["node"]
  }
}
