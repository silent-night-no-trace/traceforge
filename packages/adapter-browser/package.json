{
  "name": "@traceforge/adapter-browser",
  "version": "0.0.0",
  "description": "Browser capture adapter for Traceforge using Playwright.",
  "license": "MIT",
  "author": "Traceforge contributors",
  "keywords": [
    "traceforge",
    "browser",
    "playwright",
    "adapter",
    "capture"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@traceforge/core": "workspace:*",
    "@traceforge/schema": "workspace:*",
    "playwright": "^1.51.0"
  }
}
