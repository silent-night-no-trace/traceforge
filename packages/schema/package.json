{
  "name": "@traceforge/schema",
  "version": "0.0.0",
  "description": "Canonical Traceforge schema and capability contract.",
  "license": "MIT",
  "author": "Traceforge contributors",
  "keywords": [
    "traceforge",
    "schema",
    "zod",
    "trace",
    "events"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "zod": "^3.24.2"
  }
}
